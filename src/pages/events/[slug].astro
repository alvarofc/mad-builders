---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import { events } from '../../data/events';

export function getStaticPaths() {
  return events.map((event) => ({ params: { slug: event.slug }, props: { event } }));
}

const { event } = Astro.props;

const allPhotos = import.meta.glob<{ default: ImageMetadata }>('../../assets/events/*/*.jpeg', { eager: true });
const photos = Object.entries(allPhotos)
  .filter(([path]) => path.includes(`/events/${event.slug}/`) && !path.endsWith('cover.jpeg'))
  .sort(([a], [b]) => {
    const n = (p: string) => parseInt(p.split('/').pop() ?? '0', 10);
    return n(a) - n(b);
  })
  .map(([, m]) => m.default);

// Parse the date-only string as UTC so the rendered day doesn't shift with the
// build machine's timezone.
const [dy, dm, dd] = event.date.split('T')[0].split('-').map(Number);
const fmt = new Date(Date.UTC(dy, dm - 1, dd))
  .toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' })
  .toLowerCase();
---

<Layout title={`${event.title} — mad builders`}>
  <section class="event-page">
    <div class="wrap">
      <a href="/#events" class="mono back">← all events</a>
      <p class="kicker">{fmt}</p>
      <h1 class="section-title">{event.title}</h1>
      {event.blurb && <p class="lede">{event.blurb}</p>}
      <a class="btn event-luma" href={event.luma} target="_blank" rel="noopener">luma →</a>

      {photos.length > 0 ? (
        <div class="gallery">
          {photos.map((p, i) => (
            <button class="shot" data-index={i}>
              <Image src={p} alt={`${event.title} — photo ${i + 1}`} width={720} class="shot-img" />
            </button>
          ))}
        </div>
      ) : (
        <p class="lede no-photos">no photos yet, we were too busy building.</p>
      )}
    </div>
  </section>

  <dialog id="lightbox">
    <button id="lb-close" class="mono" aria-label="close">close ×</button>
    <button id="lb-prev" class="mono" aria-label="previous">←</button>
    <div id="lb-stage">
      {photos.map((p, i) => (
        <Image src={p} alt={`${event.title} — photo ${i + 1}`} width={1600} class="lb-img" data-index={i} loading="lazy" />
      ))}
    </div>
    <button id="lb-next" class="mono" aria-label="next">→</button>
  </dialog>
</Layout>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const imgs = [...dialog.querySelectorAll<HTMLImageElement>('.lb-img')];
  let current = 0;

  const show = (i: number) => {
    current = (i + imgs.length) % imgs.length;
    imgs.forEach((img, j) => (img.style.display = j === current ? 'block' : 'none'));
  };

  document.querySelectorAll<HTMLButtonElement>('.shot').forEach((btn) => {
    btn.addEventListener('click', () => {
      show(Number(btn.dataset.index));
      dialog.showModal();
    });
  });

  document.getElementById('lb-close')!.addEventListener('click', () => dialog.close());
  document.getElementById('lb-prev')!.addEventListener('click', () => show(current - 1));
  document.getElementById('lb-next')!.addEventListener('click', () => show(current + 1));
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
  document.addEventListener('keydown', (e) => {
    if (!dialog.open) return;
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

<style>
  .event-page {
    padding: 80px 0 110px;
  }
  /* event titles are proper names — don't lowercase them like section titles */
  .event-page h1.section-title {
    text-transform: none;
  }
  .back {
    display: inline-block;
    color: var(--cream-faint);
    text-decoration: none;
    margin-bottom: 36px;
  }
  .back:hover {
    color: var(--cream);
  }
  .event-luma {
    margin-top: 30px;
  }
  .no-photos {
    margin-top: 56px;
  }

  .gallery {
    columns: 3 300px;
    column-gap: 14px;
    margin-top: 56px;
  }
  .shot {
    display: block;
    width: 100%;
    border: 0;
    padding: 0;
    margin: 0 0 14px;
    background: none;
    cursor: zoom-in;
    break-inside: avoid;
  }
  .shot :global(.shot-img) {
    width: 100%;
    height: auto;
    border-radius: 6px;
  }

  dialog {
    background: rgba(16, 30, 25, 0.96);
    border: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    display: none;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 24px;
  }
  dialog[open] {
    display: flex;
  }
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }
  #lb-stage {
    max-width: min(1200px, 84vw);
    max-height: 88vh;
  }
  #lb-stage :global(.lb-img) {
    display: none;
    max-width: 100%;
    max-height: 88vh;
    width: auto;
    height: auto;
    border-radius: 6px;
  }
  dialog button {
    background: none;
    border: 1px solid var(--line);
    color: var(--cream);
    border-radius: 999px;
    padding: 10px 18px;
    cursor: pointer;
    font-size: 14px;
  }
  dialog button:hover {
    background: var(--cream);
    color: var(--green);
  }
  #lb-close {
    position: absolute;
    top: 20px;
    right: 20px;
  }
</style>
