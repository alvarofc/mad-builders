---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="qr generator | mad.builders" noindex={true}>
  <section class="section qr-page">
    <div class="wrap">
      <a href="/brand#assets" class="mono back">← brand guide</a>
      <p class="kicker">brand · tools</p>
      <h1 class="section-title">qr generator</h1>
      <p class="lede">
        Paste a URL, add an optional caption, and download a branded QR for stickers,
        posters and decks. Everything runs in your browser.
      </p>

      <div class="qr-layout">
        <form class="qr-form" autocomplete="off">
          <label class="qr-field">
            <span class="qr-label mono">url</span>
            <input id="qr-url" type="text" placeholder="https://chat.whatsapp.com/..." value="https://mad.builders" />
          </label>
          <label class="qr-field">
            <span class="qr-label mono">caption (optional)</span>
            <input id="qr-caption" type="text" maxlength="40" placeholder="mad.builders" />
          </label>
          <p class="qr-error mono" id="qr-error" hidden></p>
        </form>

        <div class="qr-preview">
          <div class="qr-canvas-wrap">
            <canvas id="qr-canvas" aria-label="qr code preview"></canvas>
          </div>
          <div class="qr-actions">
            <button class="btn solid" id="dl-png" type="button">download png</button>
            <button class="btn" id="dl-svg" type="button">download svg</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { qrcodegen } from '../../lib/qrcodegen';
  const QrCode = qrcodegen.QrCode;

  const GREEN = '#1a342b';
  const CREAM = '#f6f5f0';
  const SCALE = 10;
  const QUIET = 4;

  const urlInput = document.getElementById('qr-url') as HTMLInputElement;
  const capInput = document.getElementById('qr-caption') as HTMLInputElement;
  const canvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
  const errEl = document.getElementById('qr-error') as HTMLElement;
  const ctx = canvas.getContext('2d')!;

  const escapeXml = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

  // Returns { n, dark(x,y), px, capPad, capFont } for the current inputs, or null on error.
  function build() {
    const url = urlInput.value.trim();
    if (!url) return null;
    const qr = QrCode.encodeText(url, QrCode.Ecc.MEDIUM);
    const n = qr.size;
    const px = (n + QUIET * 2) * SCALE;
    const caption = capInput.value.trim();
    const capFont = Math.round(SCALE * 2.6);
    const capPad = caption ? Math.round(capFont * 2.2) : 0;
    return { qr, n, px, caption, capFont, capPad };
  }

  function render() {
    errEl.hidden = true;
    let data;
    try {
      data = build();
    } catch {
      errEl.textContent = 'that url is too long to fit in a single qr.';
      errEl.hidden = false;
      return;
    }
    if (!data) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      return;
    }
    const { qr, n, px, caption, capFont, capPad } = data;
    canvas.width = px;
    canvas.height = px + capPad;
    ctx.fillStyle = CREAM;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = GREEN;
    for (let y = 0; y < n; y++) {
      for (let x = 0; x < n; x++) {
        if (qr.getModule(x, y)) ctx.fillRect((x + QUIET) * SCALE, (y + QUIET) * SCALE, SCALE, SCALE);
      }
    }
    if (caption) {
      ctx.fillStyle = GREEN;
      ctx.font = `500 ${capFont}px "Bricolage Grotesque", sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(caption, px / 2, px + capPad / 2 - SCALE);
    }
  }

  function buildSvg() {
    const data = build();
    if (!data) return null;
    const { qr, n, px, caption, capFont, capPad } = data;
    let path = '';
    for (let y = 0; y < n; y++) {
      for (let x = 0; x < n; x++) {
        if (qr.getModule(x, y)) path += `M${(x + QUIET) * SCALE} ${(y + QUIET) * SCALE}h${SCALE}v${SCALE}h-${SCALE}z`;
      }
    }
    const h = px + capPad;
    let svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${px}" height="${h}" viewBox="0 0 ${px} ${h}">`;
    svg += `<rect width="${px}" height="${h}" fill="${CREAM}"/>`;
    svg += `<path d="${path}" fill="${GREEN}"/>`;
    if (caption)
      svg += `<text x="${px / 2}" y="${px + capPad / 2 - SCALE}" fill="${GREEN}" font-family="Bricolage Grotesque, sans-serif" font-weight="500" font-size="${capFont}" text-anchor="middle" dominant-baseline="middle">${escapeXml(caption)}</text>`;
    svg += '</svg>';
    return svg;
  }

  function download(href: string, ext: string) {
    const a = document.createElement('a');
    a.href = href;
    a.download = `mad-builders-qr.${ext}`;
    a.click();
  }

  document.getElementById('dl-png')!.addEventListener('click', () => {
    if (!build()) return;
    download(canvas.toDataURL('image/png'), 'png');
  });
  document.getElementById('dl-svg')!.addEventListener('click', () => {
    const svg = buildSvg();
    if (!svg) return;
    download(URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' })), 'svg');
  });

  let t: number;
  const onInput = () => {
    clearTimeout(t);
    t = window.setTimeout(render, 120);
  };
  urlInput.addEventListener('input', onInput);
  capInput.addEventListener('input', onInput);

  // Wait for the brand font so the caption renders correctly on first paint.
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(render);
  render();
</script>

<style>
  .qr-page {
    padding-top: 72px;
  }
  .back {
    display: inline-block;
    color: var(--cream-faint);
    text-decoration: none;
    margin-bottom: 28px;
  }
  .back:hover {
    color: var(--cream);
  }
  .qr-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 48px;
    align-items: start;
  }
  @media (max-width: 720px) {
    .qr-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  .qr-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .qr-field {
    display: block;
  }
  .qr-label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--cream-faint);
    margin-bottom: 10px;
  }
  .qr-field input {
    width: 100%;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 13px 14px;
    color: var(--cream);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .qr-field input:focus {
    outline: none;
    border-color: var(--cream-dim);
  }
  .qr-error {
    color: #e58a6f;
    font-size: 12px;
    margin: 0;
  }
  .qr-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .qr-canvas-wrap {
    background: var(--cream);
    border-radius: 12px;
    padding: 18px;
    width: 100%;
    max-width: 360px;
  }
  #qr-canvas {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
  }
  .qr-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
