---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

// Pulled straight from the design tokens in src/styles/global.css so this page
// can't drift from the real site.
const greens = [
  { name: '--green', hex: '#1a342b', use: 'primary background, the brand green' },
  { name: '--green-deep', hex: '#142a22', use: 'footer / deepest surface' },
  { name: '--green-soft', hex: '#214136', use: 'raised surfaces on green' },
];
const inks = [
  { name: '--cream', hex: '#f6f5f0', use: 'primary ink on green · light-section background' },
  { name: '--cream-dim', hex: 'rgba(246,245,240,0.62)', use: 'secondary text' },
  { name: '--cream-faint', hex: 'rgba(246,245,240,0.38)', use: 'kickers / tertiary text' },
  { name: '--line', hex: 'rgba(246,245,240,0.14)', use: 'hairline borders' },
];

const fonts = [
  {
    name: 'Bricolage Grotesque',
    role: 'logo',
    where: 'the mad.builders wordmark, and nothing else',
    sample: 'mad.builders',
    family: "'Bricolage Grotesque', sans-serif",
    weight: 500,
    size: '34px',
  },
  {
    name: 'Archivo',
    role: 'body',
    where: 'headings, hero, body copy, cards and UI. the workhorse',
    sample: "the builders' house",
    family: "'Archivo', sans-serif",
    weight: 600,
    size: '34px',
  },
  {
    name: 'IBM Plex Mono',
    role: 'other',
    where: 'kickers, buttons, nav, ticker, footer. uppercase and letter-spaced',
    sample: 'WHAT THIS IS ///',
    family: "'IBM Plex Mono', monospace",
    weight: 500,
    size: '22px',
  },
];

const dos = [
  'sentence-case section titles: capital first letter only ("The deal", "Off-hours")',
  'lowercase for card headings and terse lines ("a real house", "no bullshit. just building.")',
  'short, concrete, plain words',
  'builder-first, with a little Madrid flavour ("siesta", "tapas")',
  'periods and commas over em-dashes',
];
const donts = [
  'Title Case (capitalising every word) or ALL-CAPS headlines',
  'corporate fluff, hype words, buzzwords',
  'jargon when a plain word works',
  'em-dash pile-ups and other "AI tells"',
];
---

<Layout title="brand guide | mad.builders" noindex={true}>
  <nav class="brand-toc mono" aria-label="brand guide sections">
    <div class="wrap brand-toc-inner">
      <a href="#logo">logo</a>
      <a href="#colour">colour</a>
      <a href="#type">type</a>
      <a href="#voice">voice</a>
      <a href="#photography">photo</a>
      <a href="#focus">focus</a>
      <a href="#assets">assets</a>
    </div>
  </nav>
  <section class="section brand-head">
    <div class="wrap">
      <p class="kicker">brand guide</p>
      <h1 class="section-title">the look &amp; the voice</h1>
      <p class="lede">
        The single reference for the mad.builders identity: logo, colour, type and tone.
      </p>
    </div>
  </section>

  <!-- LOGO -->
  <section class="section light" id="logo">
    <div class="wrap">
      <h2 class="section-title numbered">01 · Logo</h2>
      <p class="lede">
        Bricolage Grotesque, medium weight. The dot stays dimmed to the same tone as
        “builders”. Two lockups only: cream on green, or green on cream.
      </p>
      <div class="logo-boards">
        <div class="board green-board">
          <span class="mark">mad<span class="mark-dot">.builders</span></span>
        </div>
        <div class="board cream-board">
          <span class="mark mark-ink">mad<span class="mark-dot-ink">.builders</span></span>
        </div>
      </div>
      <div class="rules">
        <div class="rule do">
          <p class="rule-h mono">do</p>
          <ul>
            <li>keep the dimmed dot, it’s part of the mark</li>
            <li>give it clear space (≈ the height of the “m” all around)</li>
            <li>cream-on-green or green-on-cream, nothing else</li>
          </ul>
        </div>
        <div class="rule dont">
          <p class="rule-h mono">don’t</p>
          <ul>
            <li>recolour, add shadows, outlines or gradients</li>
            <li>change the weight of “mad” vs the dimmed “.builders”</li>
            <li>stretch, condense, or set it on a busy photo without a scrim</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- COLOUR -->
  <section class="section" id="colour">
    <div class="wrap">
      <h2 class="section-title numbered">02 · Colour</h2>
      <p class="lede">
        Deep green and warm cream carry everything. Sponsor colours (e.g. Samplia red) live
        only inside a sponsor’s own logo, never in the core palette.
      </p>
      <div class="kicker sub mono">surfaces</div>
      <div class="swatches">
        {greens.map((c) => (
          <div class="swatch">
            <span class="chip" style={`background:${c.hex}`}></span>
            <p class="sw-name mono">{c.name}</p>
            <p class="sw-hex mono">{c.hex}</p>
            <p class="sw-use">{c.use}</p>
          </div>
        ))}
      </div>
      <div class="kicker sub mono">ink &amp; lines</div>
      <div class="swatches">
        {inks.map((c) => (
          <div class="swatch">
            <span class={`chip ${c.name === '--cream' ? '' : 'chip-on-green'}`} style={`background:${c.hex}`}></span>
            <p class="sw-name mono">{c.name}</p>
            <p class="sw-hex mono">{c.hex}</p>
            <p class="sw-use">{c.use}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TYPE -->
  <section class="section light" id="type">
    <div class="wrap">
      <h2 class="section-title numbered">03 · Type</h2>
      <p class="lede">Each does one job. Don’t mix the roles.</p>
      <div class="specimens">
        {fonts.map((f) => (
          <div class="specimen">
            <div class="spec-meta">
              <p class="sw-name mono">{f.name}</p>
              <span class="role-tag mono">{f.role}</span>
            </div>
            <p class="spec-sample" style={`font-family:${f.family};font-weight:${f.weight};font-size:${f.size}`}>
              {f.sample}
            </p>
            <p class="spec-where">{f.where}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VOICE -->
  <section class="section" id="voice">
    <div class="wrap">
      <h2 class="section-title numbered">04 · Voice</h2>
      <p class="lede">
        Terse, mostly lowercase, a bit irreverent. It should sound like a builder, not a brochure.
        Ease off when talking to VCs and sponsors: stay clear, skip the crude.
      </p>
      <div class="rules">
        <div class="rule do">
          <p class="rule-h mono">do</p>
          <ul>{dos.map((d) => <li>{d}</li>)}</ul>
        </div>
        <div class="rule dont">
          <p class="rule-h mono">don’t</p>
          <ul>{donts.map((d) => <li>{d}</li>)}</ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PHOTOGRAPHY -->
  <section class="section light" id="photography">
    <div class="wrap">
      <h2 class="section-title numbered">05 · Photography</h2>
      <p class="lede">
        Real moments from the house: rooftops, talks, packed rooms at golden hour. Slightly
        desaturated (<code>filter: saturate(0.92)</code>) so nothing screams. Edges fade into
        the green in the strips. Never staged stock.
      </p>
    </div>
  </section>

  <!-- FOCUS -->
  <section class="section" id="focus">
    <div class="wrap">
      <h2 class="section-title numbered">06 · Focus</h2>
      <p class="lede">What gets built here.</p>
      <div class="focus-tags mono">
        {site.focus.map((f, i) => (
          <span class="focus-tag">{f}{i < site.focus.length - 1 && <i> ///</i>}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ASSETS -->
  <section class="section light" id="assets">
    <div class="wrap">
      <h2 class="section-title numbered">07 · Assets</h2>
      <p class="lede">Logos, stickers, and a QR generator.</p>
      <div class="asset-grid">
        <div class="asset-card">
          <p class="asset-h">logo files</p>
          <p class="asset-note">svg + png lockups, cream-on-green and green-on-cream. drop them in <code>src/assets/brand/</code> and we link them here.</p>
        </div>
        <div class="asset-card">
          <p class="asset-h">stickers</p>
          <p class="asset-note">sticker artwork for events and laptops. coming once the designs land.</p>
        </div>
      </div>

      <div class="qr-tool">
        <p class="kicker sub mono">qr generator</p>
        <div class="qr-layout">
          <form class="qr-form" autocomplete="off">
            <label class="qr-field">
              <span class="qr-label mono">url</span>
              <input id="qr-url" type="text" placeholder="https://chat.whatsapp.com/..." value="https://mad.builders" />
            </label>
            <label class="qr-check">
              <input id="qr-brand" type="checkbox" checked />
              <span class="mono">add the mad.builders mark</span>
            </label>
            <label class="qr-check">
              <input id="qr-url-show" type="checkbox" />
              <span class="mono">show the url</span>
            </label>
            <p class="qr-error mono" id="qr-error" hidden></p>
          </form>
          <div class="qr-preview">
            <div class="qr-canvas-wrap">
              <canvas id="qr-canvas" aria-label="qr code preview"></canvas>
            </div>
            <button class="btn solid" id="dl-png" type="button">download png</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { qrcodegen } from '../lib/qrcodegen';
  const QrCode = qrcodegen.QrCode;

  const urlInput = document.getElementById('qr-url') as HTMLInputElement | null;
  if (urlInput) {
    const GREEN = '#1a342b';
    const CREAM = '#f6f5f0';
    const DIM = 'rgba(26, 52, 43, 0.5)';
    const FONT = '"Bricolage Grotesque", sans-serif';
    const MONO = '"IBM Plex Mono", monospace';
    const SCALE = 16;
    const QUIET = 4;

    const brandInput = document.getElementById('qr-brand') as HTMLInputElement;
    const urlShow = document.getElementById('qr-url-show') as HTMLInputElement;
    const canvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
    const errEl = document.getElementById('qr-error') as HTMLElement;
    const ctx = canvas.getContext('2d')!;

    function build() {
      const url = urlInput!.value.trim();
      if (!url) return null;
      const qr = QrCode.encodeText(url, QrCode.Ecc.MEDIUM);
      return { qr, url, branded: brandInput.checked, showUrl: urlShow.checked };
    }

    // Strip protocol, www and trailing slash.
    const cleanUrl = (u: string) => u.replace(/^https?:\/\//, '').replace(/^www\./, '').replace(/\/+$/, '');
    // Wrap to as many lines as needed to show the whole string (ctx.font set by caller).
    function wrap(text: string, maxW: number) {
      const out: string[] = [];
      let cur = '';
      for (const ch of text) {
        if (cur && ctx.measureText(cur + ch).width > maxW) {
          out.push(cur);
          cur = ch;
        } else cur += ch;
      }
      if (cur) out.push(cur);
      return out;
    }
    function drawMark(cx: number, top: number, fs: number) {
      ctx.font = `500 ${fs}px ${FONT}`;
      ctx.textBaseline = 'top';
      ctx.textAlign = 'left';
      const madW = ctx.measureText('mad').width;
      const total = madW + ctx.measureText('.builders').width;
      const tx = cx - total / 2;
      ctx.fillStyle = GREEN;
      ctx.fillText('mad', tx, top);
      ctx.fillStyle = DIM;
      ctx.fillText('.builders', tx + madW, top);
    }

    function render() {
      errEl.hidden = true;
      let data;
      try {
        data = build();
      } catch {
        errEl.textContent = 'that url is too long to fit in a single qr.';
        errEl.hidden = false;
        return;
      }
      if (!data) {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        return;
      }
      const { qr, url, branded, showUrl } = data;
      const n = qr.size;
      const px = (n + QUIET * 2) * SCALE;
      const codeTop = QUIET * SCALE;
      const codeBottom = (n + QUIET) * SCALE;
      const fsW = Math.round(SCALE * 2.2);
      const fsU = Math.round(SCALE * 1.25);
      const lineGap = Math.round(SCALE * 0.5);
      const edge = Math.round(SCALE * 1.4);
      const wordmarkTop = showUrl && branded;

      // Lay out captions in QR-block coords (block spans [0, px]).
      const items: { kind: 'mark' | 'url'; text?: string; fs: number; top: number }[] = [];
      let minY = 0;
      let maxY = px;
      if (wordmarkTop) {
        const top = codeTop - SCALE - fsW; // wordmark ends ~1 module above the code (matches the url gap below)
        items.push({ kind: 'mark', fs: fsW, top });
        minY = Math.min(minY, top - edge);
      }
      if (showUrl) {
        ctx.font = `${fsU}px ${MONO}`;
        let cy = codeBottom + SCALE; // ~1 module below the code
        for (const line of wrap(cleanUrl(url), px * 0.92)) {
          items.push({ kind: 'url', text: line, fs: fsU, top: cy });
          cy += fsU + lineGap;
        }
        maxY = Math.max(maxY, cy - lineGap + edge);
      } else if (branded) {
        const top = codeBottom + SCALE;
        items.push({ kind: 'mark', fs: fsW, top });
        maxY = Math.max(maxY, top + fsW + edge);
      }

      const shift = -minY;
      canvas.width = px;
      canvas.height = Math.round(maxY - minY);
      ctx.fillStyle = CREAM;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = GREEN;
      for (let y = 0; y < n; y++)
        for (let x = 0; x < n; x++)
          if (qr.getModule(x, y)) ctx.fillRect((x + QUIET) * SCALE, (y + QUIET) * SCALE + shift, SCALE, SCALE);

      ctx.textBaseline = 'top';
      for (const it of items) {
        if (it.kind === 'mark') {
          drawMark(px / 2, it.top + shift, it.fs);
        } else {
          ctx.font = `${it.fs}px ${MONO}`;
          ctx.textAlign = 'center';
          ctx.fillStyle = DIM;
          ctx.fillText(it.text!, px / 2, it.top + shift);
        }
      }
    }

    document.getElementById('dl-png')!.addEventListener('click', () => {
      if (!build()) return;
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'mad-builders-qr.png';
      a.click();
    });

    let t: number;
    const onInput = () => {
      clearTimeout(t);
      t = window.setTimeout(render, 120);
    };
    urlInput.addEventListener('input', onInput);
    brandInput.addEventListener('change', render);
    urlShow.addEventListener('change', render);

    // Wait for the brand font so the wordmark renders correctly on first paint.
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(render);
    render();
  }

  // Highlight the TOC link for the section currently in view.
  const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>('.brand-toc a')];
  const linkFor = new Map(tocLinks.map((a) => [a.getAttribute('href')!.slice(1), a]));
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        tocLinks.forEach((a) => a.classList.remove('active'));
        linkFor.get((e.target as HTMLElement).id)?.classList.add('active');
      }
    },
    { rootMargin: '-45% 0px -50% 0px' }
  );
  document.querySelectorAll('section[id]').forEach((s) => spy.observe(s));
</script>

<style>
  .brand-head {
    padding-top: 64px;
    padding-bottom: 36px;
  }

  /* logo boards */
  .logo-boards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin-top: 40px;
  }
  .board {
    border-radius: 12px;
    padding: 48px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .green-board {
    background: var(--green-soft);
    border: 1px solid var(--line);
  }
  .cream-board {
    background: var(--cream);
    border: 1px solid rgba(26, 52, 43, 0.12);
  }
  .mark {
    font-family: 'Bricolage Grotesque', var(--font-sans);
    font-weight: 500;
    font-size: 32px;
    letter-spacing: -0.02em;
    color: var(--cream);
  }
  .mark-dot {
    color: var(--cream-dim);
    font-weight: 400;
  }
  .mark-ink {
    color: var(--green);
  }
  .mark-dot-ink {
    color: rgba(26, 52, 43, 0.55);
    font-weight: 400;
  }

  /* do / don't */
  .rules {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 18px;
    margin-top: 36px;
  }
  .rule {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 22px 24px;
  }
  .rule-h {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 14px;
    font-size: 12px;
  }
  .rule.do .rule-h {
    color: #97c459;
  }
  .rule.dont .rule-h {
    color: #e58a6f;
  }
  .rule ul {
    margin: 0;
    padding-left: 18px;
    color: var(--cream-dim);
  }
  .rule li {
    margin-bottom: 8px;
    line-height: 1.5;
  }

  /* swatches */
  .sub {
    margin: 36px 0 14px;
  }
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }
  .chip {
    display: block;
    height: 72px;
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .chip-on-green {
    border: 1px solid var(--line);
  }
  .sw-name {
    font-size: 13px;
    margin: 0 0 2px;
  }
  .sw-hex {
    font-size: 12px;
    color: var(--cream-faint);
    margin: 0 0 6px;
  }
  .sw-use {
    font-size: 14px;
    color: var(--cream-dim);
    margin: 0;
    line-height: 1.45;
  }

  /* type specimens */
  .specimens {
    display: grid;
    gap: 16px;
    margin-top: 36px;
  }
  .specimen {
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 24px 26px;
  }
  .spec-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .role-tag {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--cream-faint);
  }
  .spec-sample {
    margin: 0 0 12px;
    line-height: 1.1;
    color: var(--cream);
  }
  .spec-where {
    margin: 0;
    color: var(--cream-dim);
    font-size: 14px;
  }

  /* focus tags */
  .focus-tags {
    margin-top: 32px;
    font-size: 15px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
    line-height: 2;
  }
  .focus-tag i {
    color: var(--cream-faint);
    font-style: normal;
    margin: 0 6px;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--green-soft);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* green-ink overrides for components sitting on cream (.section.light) */
  .section.light .rule,
  .section.light .specimen {
    border-color: rgba(26, 52, 43, 0.14);
  }
  .section.light .rule ul,
  .section.light .spec-where {
    color: rgba(26, 52, 43, 0.72);
  }
  .section.light .rule.do .rule-h {
    color: #3b6d11;
  }
  .section.light .rule.dont .rule-h {
    color: #993c1d;
  }
  .section.light .sw-name,
  .section.light .spec-sample {
    color: var(--green);
  }
  .section.light .role-tag {
    color: rgba(26, 52, 43, 0.5);
  }
  .section.light code {
    background: rgba(26, 52, 43, 0.08);
    color: var(--green);
  }

  /* docs layout: sticky section nav + tighter density */
  .brand-toc {
    position: sticky;
    top: 64px;
    z-index: 90;
    background: color-mix(in srgb, var(--green) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .brand-toc-inner {
    display: flex;
    gap: 22px;
    align-items: center;
    height: 46px;
    overflow-x: auto;
    scrollbar-width: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .brand-toc-inner::-webkit-scrollbar {
    display: none;
  }
  .brand-toc a {
    color: var(--cream-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .brand-toc a:hover,
  .brand-toc a.active {
    color: var(--cream);
  }
  .brand-toc a.active {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }

  .section {
    padding: 56px 0;
  }
  section[id] {
    scroll-margin-top: 118px;
  }

  /* assets */
  .asset-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 36px;
  }
  .asset-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 22px 24px;
    text-decoration: none;
    color: inherit;
  }
  .asset-h {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .asset-note {
    margin: 0;
    color: var(--cream-dim);
    font-size: 14px;
    line-height: 1.5;
  }
  a.asset-card:hover {
    border-color: var(--cream-dim);
  }
  .section.light .asset-card {
    border-color: rgba(26, 52, 43, 0.14);
  }
  .section.light .asset-note {
    color: rgba(26, 52, 43, 0.72);
  }
  .section.light a.asset-card:hover {
    border-color: rgba(26, 52, 43, 0.4);
  }

  /* inline qr generator (under assets, on cream) */
  .qr-tool {
    margin-top: 44px;
  }
  .qr-tool .sub {
    margin: 0 0 20px;
  }
  .qr-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    align-items: start;
  }
  @media (max-width: 720px) {
    .qr-layout {
      grid-template-columns: 1fr;
