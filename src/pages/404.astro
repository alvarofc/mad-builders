---
import Layout from '../layouts/Layout.astro'

const title = 'Page Not Found — MAD BUILDERS'
const description = '404 error - The requested page could not be found on MAD BUILDERS.'
---

<Layout title={title} description={description} noindex={true}>
	<Fragment slot="head">
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@500;600&display=swap" rel="stylesheet" />
	</Fragment>
	<div class="error-page">
		<div class="error-content">
			<span class="error-code">404</span>
			<h2 class="error-headline">Page not found.</h2>
			<p class="error-text">The page you're looking for doesn't exist or has been moved.</p>
			<a href="/" class="error-link">Back to home</a>
		</div>
	</div>
</Layout>

<style>
	.error-page {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		background: #FFFFFF;
		font-family: 'Geist', -apple-system, BlinkMacSystemFont, sans-serif;
	}

	.error-content {
		text-align: center;
		max-width: 480px;
	}

	.error-code {
		font-family: 'Geist Mono', monospace;
		font-size: clamp(6rem, 15vw, 12rem);
		font-weight: 500;
		color: #EAEAEA;
		line-height: 1;
		display: block;
		margin-bottom: 1rem;
		letter-spacing: -0.05em;
	}

	.error-headline {
		font-family: 'Geist', -apple-system, sans-serif;
		font-size: 1.75rem;
		font-weight: 500;
		color: #0A0A0A;
		margin: 0 0 1rem;
		letter-spacing: -0.02em;
	}

	.error-text {
		color: #555555;
		font-size: 1rem;
		line-height: 1.6;
		margin: 0 0 2rem;
	}

	.error-link {
		display: inline-block;
		font-family: 'Geist', sans-serif;
		font-size: 0.9rem;
		font-weight: 500;
		color: #FFFFFF;
		background: #0A0A0A;
		text-decoration: none;
		padding: 0.75rem 2rem;
		border-radius: 99px;
		transition: background 0.2s ease, transform 0.2s ease;
	}

	.error-link:hover {
		background: #333333;
		transform: translateY(-2px);
	}
</style>
