---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title="404 — lost in madrid · mad builders" description="This page doesn't exist." noindex={true}>
  <section class="section notfound">
    <div class="wrap">
      <p class="kicker">error 404</p>
      <h1 class="section-title">lost in madrid</h1>
      <p class="lede">
        this page packed up and left the building. it happens. let's get you back to where the
        builders are.
      </p>
      <div class="actions">
        <a class="btn solid" href="/">← back home</a>
        <a class="btn" href={site.whatsapp} target="_blank" rel="noopener">join the whatsapp →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
</style>
