---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title="404 | mad.builders" description="This page doesn't exist." noindex={true}>
  <section class="section notfound">
    <div class="wrap">
      <p class="kicker">error 404</p>
      <h1 class="section-title">lost in <span class="proper">Madrid</span></h1>
      <p class="lede">
        this page is probably out for a siesta or grabbing some tapas. let's get you back to
        where the builders are.
      </p>
      <div class="actions">
        <a class="btn solid" href="/">← home</a>
        <a class="btn" href={site.whatsapp} target="_blank" rel="noopener">whatsapp group →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .section-title .proper {
    text-transform: none;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
</style>
