---
import Layout from '../layouts/Layout.astro';
import { absoluteUrl, DEFAULT_DESCRIPTION, SITE_NAME, SAME_AS } from '../config/seo'

const title = 'MAD BUILDERS — Where founders build.'
const description = 'A free workspace, a curated community, and a launchpad for founders building real companies. Curated. Selective. Based in Madrid.'

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    'name': SITE_NAME,
    'url': absoluteUrl('/'),
    'description': DEFAULT_DESCRIPTION,
    'foundingDate': '2024',
    'areaServed': {
      '@type': 'Place',
      'name': 'Madrid, Spain'
    },
    'parentOrganization': {
      '@type': 'Organization',
      'name': 'Startup Embassy',
      'url': 'https://www.startupembassy.com/',
      'foundingDate': '2012',
      'description': 'The oldest entrepreneurial coliving in Palo Alto, Silicon Valley'
    },
    'sameAs': SAME_AS
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    'url': absoluteUrl('/'),
    'name': SITE_NAME,
    'inLanguage': 'en'
  }
]

const builders = [
  { name: 'Carlos Reines',    role: 'Co-founder', company: 'Samplia',          building: 'Reinventing product sampling with AI-driven logistics',    url: 'https://samplia.com/',              color: '#2C4238' },
  { name: 'Jordi Hales',      role: 'Co-founder', company: 'Startup Embassy',  building: 'Building global founder communities since 2012',           url: 'https://startupembassy.com/',       color: '#3A2E52' },
  { name: 'Gonzalo Manrique', role: 'Co-founder', company: 'Ironhack',         building: 'Largest tech bootcamp in Europe & LatAm',                  url: 'https://www.ironhack.com/',         color: '#4A2E1C' },
  { name: 'Ignacio Arriaga',  role: 'Founder',    company: 'Acumbamail',       building: 'Email marketing platform, bootstrapped to profitability',  url: 'https://acumbamail.com/',           color: '#1E3248' },
  { name: 'Diego Ballesteros',role: 'Co-founder', company: 'Nomorepass',       building: 'Password manager that never stores passwords',             url: 'https://nomorepass.com/',           color: '#3E2430' },
  { name: 'Pablo Villalba',   role: 'Founder',    company: 'Aulean',           building: 'Enterprise AI solutions for smarter operations',           url: 'https://aulean.com/',               color: '#1E3C38' },
]

const faqs = [
  { q: 'Is it really free?',        a: 'Yes. No membership fees, no equity, no hidden costs. We believe the best communities are generous by default.' },
  { q: 'Do I need to be a founder?',a: 'Yes. This community is built for founders — people with skin in the game, building companies they believe in.' },
  { q: 'How selective is it?',      a: 'Very. We keep the community small and high-quality. We look for momentum, generosity, and proof of work.' },
  { q: 'What\'s expected of members?',a: 'Show up. Share your progress. Help others. Build things.' },
  { q: 'Who\'s behind Mad Builders?', a: 'Founders who\'ve been through it. Operators, not spectators. People who wanted this community to exist and decided to build it.' },
  { q: 'Can I join remotely?',      a: 'No. This is an in-person community. That\'s the point.' },
]
---

<Layout title={title} description={description} structuredData={structuredData}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </Fragment>

  <div class="page">

    <!-- ============ NAV ============ -->
    <nav class="nav" id="nav">
      <div class="nav-inner">
        <a href="/" class="logo-badge" aria-label="Mad Builders home">mad <span class="logo-builders">builders</span></a>
        <a href="#apply" class="nav-cta">Apply now <span class="nav-arrow">→</span></a>
      </div>
    </nav>

    <!-- ============ HERO ============ -->
    <section class="hero" id="hero">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="hero-eyebrow reveal">Madrid, Spain &mdash; Est. 2024</p>
          <h2 class="hero-headline reveal">
            The<br/><em>builders'</em><br/>house.
          </h2>
          <p class="hero-sub reveal">A free workspace, a curated community, and a launchpad for founders building real companies. No coworking fluff. No networking theater. Just building.</p>
          <div class="hero-actions reveal">
            <a href="#apply" class="btn-hero">Apply now</a>
            <span class="hero-note">Rolling admissions · Limited spots</span>
          </div>
        </div>
        <div class="hero-faces" aria-label="Community members">
          {builders.map((b, i) => (
            <div
              class="face-card reveal"
              style={`--card-color: ${b.color}; transition-delay: ${0.08 + i * 0.06}s`}
            >
              <div class="face-photo" style={`background-color: ${b.color}`}>
                <svg class="face-silhouette" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="40" cy="32" r="19" fill="rgba(247,245,240,0.2)"/>
                  <path d="M4 100 Q4 68 40 68 Q76 68 76 100" fill="rgba(247,245,240,0.2)"/>
                </svg>
                <div class="face-firstname">{b.name.split(' ')[0]}</div>
              </div>
              <div class="face-caption">
                <span class="face-fullname">{b.name}</span>
                <span class="face-company">{b.company}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-scroll" id="scroll-hint">
        <div class="scroll-bar"></div>
      </div>
    </section>

    <!-- ============ PROBLEM ============ -->
    <section class="section section-problem" id="problem">
      <div class="container">
        <div class="problem-layout">
          <div class="problem-left reveal">
            <p class="problem-pull">&ldquo;You know<br/>the feeling.&rdquo;</p>
          </div>
          <div class="problem-right">
            <div class="problem-body reveal">
              <p>You&rsquo;re building something real, but you&rsquo;re doing it alone. The coworking space has bean bags and networking events where nobody follows up. The startup meetups are full of people with pitch decks and no product.</p>
              <p>You want to be around people who actually ship &mdash; other founders who&rsquo;ve felt what you feel, who&rsquo;ll call your bluff and have your back.</p>
            </div>
            <p class="problem-bridge reveal">Until now.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WHO ============ -->
    <section class="section section-who" id="who">
      <div class="container">
        <h2 class="section-title reveal">This is for <em>founders.</em></h2>
        <div class="who-rows">
          <div class="who-row reveal">
            <span class="who-num">01</span>
            <p>Founders building companies, not collecting job titles.</p>
          </div>
          <div class="who-row reveal">
            <span class="who-num">02</span>
            <p>People who bet on themselves before anyone else did.</p>
          </div>
          <div class="who-row reveal">
            <span class="who-num">03</span>
            <p>Those who&rsquo;ve shipped &mdash; or are so close they can&rsquo;t sleep.</p>
          </div>
          <div class="who-row reveal">
            <span class="who-num">04</span>
            <p>People who give before they ask.</p>
          </div>
        </div>
        <p class="who-note reveal">If you need permission to build, this isn&rsquo;t your place.</p>
      </div>
    </section>

    <!-- ============ COMMUNITY ============ -->
    <section class="section section-community" id="community">
      <div class="container">
        <div class="community-header">
          <h2 class="section-title section-title-inv reveal">The <em>builders.</em></h2>
          <p class="community-sub reveal">Shipping products, raising rounds, and building the companies the world will remember.</p>
        </div>
        <div class="builders-grid">
          {builders.map((b) => (
            <a href={b.url} target="_blank" rel="noopener noreferrer" class="builder-card reveal">
              <div class="builder-photo" style={`background-color: ${b.color}`}>
                <svg class="builder-silhouette" viewBox="0 0 80 110" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="40" cy="34" r="21" fill="rgba(247,245,240,0.18)"/>
                  <path d="M2 110 Q2 72 40 72 Q78 72 78 110" fill="rgba(247,245,240,0.18)"/>
                </svg>
                <div class="builder-photo-tag">{b.company} →</div>
              </div>
              <div class="builder-info">
                <h3 class="builder-name">{b.name}</h3>
                <p class="builder-role">{b.role}</p>
                <p class="builder-building">{b.building}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ BENEFITS ============ -->
    <section class="section section-benefits" id="benefits">
      <div class="container">
        <h2 class="section-title reveal">Everything you need to build.<br/><em class="title-muted">Nothing you don&rsquo;t.</em></h2>
        <div class="benefits-grid">
          <div class="benefit-item reveal">
            <span class="benefit-n">01</span>
            <h3>Workspace</h3>
            <p>A permanent workspace with fast Wi-Fi and a builder-first setup.</p>
          </div>
          <div class="benefit-item reveal">
            <span class="benefit-n">02</span>
            <h3>Founder circles</h3>
            <p>Weekly sessions &mdash; not networking, actual problem-solving.</p>
          </div>
          <div class="benefit-item reveal">
            <span class="benefit-n">03</span>
            <h3>Demo days</h3>
            <p>Present in front of real investors who write real checks.</p>
          </div>
          <div class="benefit-item reveal">
            <span class="benefit-n">04</span>
            <h3>Mentorship</h3>
            <p>1:1 sessions with people who&rsquo;ve done it before.</p>
          </div>
          <div class="benefit-item reveal">
            <span class="benefit-n">05</span>
            <h3>Partner perks</h3>
            <p>Tools, credits, and discounts from companies that get it.</p>
          </div>
          <div class="benefit-item reveal">
            <span class="benefit-n">06</span>
            <h3>Community</h3>
            <p>A community that shows up for each other.</p>
          </div>
        </div>
        <div class="benefits-banner reveal">
          <span>All of it free.</span>
          <span class="banner-dot">·</span>
          <span>No membership fees.</span>
          <span class="banner-dot">·</span>
          <span>No equity.</span>
          <span class="banner-dot">·</span>
          <span>No catch.</span>
        </div>
      </div>
    </section>

    <!-- ============ STEPS ============ -->
    <section class="section section-steps" id="steps">
      <div class="container">
        <h2 class="section-title reveal">Three steps.</h2>
        <div class="steps-track">
          <div class="step reveal">
            <span class="step-n">1</span>
            <div class="step-body">
              <h3>Apply</h3>
              <p>Tell us what you&rsquo;re building and why it matters.</p>
            </div>
          </div>
          <div class="step-arrow reveal">&rarr;</div>
          <div class="step reveal">
            <span class="step-n">2</span>
            <div class="step-body">
              <h3>Meet</h3>
              <p>We&rsquo;ll have a conversation. Show us your work, not your deck.</p>
            </div>
          </div>
          <div class="step-arrow reveal">&rarr;</div>
          <div class="step reveal">
            <span class="step-n">3</span>
            <div class="step-body">
              <h3>Build</h3>
              <p>Get your spot. Start shipping from day one.</p>
            </div>
          </div>
        </div>
        <p class="steps-note reveal">Rolling admissions &middot; Limited spots &middot; Decisions in one week</p>
      </div>
    </section>

    <!-- ============ ORIGIN ============ -->
    <section class="section section-origin" id="origin">
      <div class="container">
        <h2 class="section-title reveal">From Palo Alto<br/><em class="title-muted">to Madrid.</em></h2>
        <div class="origin-layout">
          <div class="origin-text reveal">
            <p>In 2012, we opened <a href="https://www.startupembassy.com/" target="_blank" rel="noopener noreferrer">Startup Embassy</a> &mdash; a house in Palo Alto where entrepreneurs from around the world could land in Silicon Valley and start building.</p>
            <p>Over the years, 2,000+ founders from 90+ countries came through our doors. They raised $700M+. They got into YC, 500 Startups, Singularity University. TechCrunch, National Geographic, and Forbes came to tell the story.</p>
            <p>Mad Builders applies the same model &mdash; brought home to Madrid. Same conviction: put ambitious founders in a room together, remove the friction, and get out of the way.</p>
          </div>
          <div class="origin-stats reveal">
            <div class="stat">
              <span class="stat-n">2,000+</span>
              <span class="stat-l">Entrepreneurs hosted</span>
            </div>
            <div class="stat">
              <span class="stat-n">90+</span>
              <span class="stat-l">Countries represented</span>
            </div>
            <div class="stat">
              <span class="stat-n">$700M+</span>
              <span class="stat-l">Raised by alumni</span>
            </div>
            <div class="stat">
              <span class="stat-n">$2B+</span>
              <span class="stat-l">Combined valuation</span>
            </div>
          </div>
        </div>
        <div class="press-row reveal">
          <span class="press-label">As seen in</span>
          <a class="press-logo" href="https://www.nationalgeographic.com/magazine/2019/02/silicon-valley-evolving-focusing-employees/#/silicon-valley-startup-embassy-poster.jpg" target="_blank" rel="noopener noreferrer">National Geographic</a>
          <a class="press-logo" href="http://www.forbes.com.mx/el-sueno-de-silicon-valley/" target="_blank" rel="noopener noreferrer">Forbes</a>
          <a class="press-logo" href="http://tecnologia.elpais.com/tecnologia/2012/10/01/actualidad/1349112802_776849.html" target="_blank" rel="noopener noreferrer">El Pa&iacute;s</a>
          <a class="press-logo" href="https://www.cnet.com/news/hacker-hostels-let-tech-hopefuls-snooze-and-schmooze-video/" target="_blank" rel="noopener noreferrer">CNET</a>
          <a class="press-logo" href="https://www.entrepreneur.com/article/271403" target="_blank" rel="noopener noreferrer">Entrepreneur</a>
        </div>
      </div>
    </section>

    <!-- ============ MADRID ============ -->
    <section class="section-madrid" id="madrid">
      <div class="madrid-inner">
        <h2 class="madrid-word reveal">Madrid.</h2>
        <div class="madrid-body">
          <p class="madrid-desc reveal">Best quality of life in Europe. A startup ecosystem that&rsquo;s accelerating. A city full of energy, talent, and ambition.</p>
          <p class="madrid-invite reveal">We&rsquo;re based here.<br/>If you&rsquo;re a founder building something real, come find your people.</p>
        </div>
      </div>
      <div class="madrid-skyline" aria-hidden="true">
        <img src="/madrid-skyline.png" alt="" loading="lazy" width="2816" height="1536" />
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section section-faq" id="faq">
      <div class="container">
        <h2 class="section-title reveal">Questions.</h2>
        <div class="faq-grid">
          {faqs.map((faq) => (
            <div class="faq-item reveal">
              <h3 class="faq-q">{faq.q}</h3>
              <p class="faq-a">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section-cta" id="apply">
      <div class="cta-inner">
        <h2 class="cta-headline reveal">Your people<br/><em>are here.</em></h2>
        <div class="cta-action reveal">
          <a href="https://tally.so/r/w4e8yo" target="_blank" rel="noopener noreferrer" class="btn-apply">Apply now</a>
        </div>
        <p class="cta-note reveal">Founders only &middot; Limited spots &middot; No fees, ever.</p>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="footer">
      <div class="footer-inner">
        <a href="/" class="logo-badge logo-badge-sm" aria-label="Mad Builders home">mad <span class="logo-builders">builders</span></a>
        <div class="footer-right">
          <span class="footer-tagline">Where founders build.</span>
        </div>
      </div>
    </footer>

  </div>
</Layout>


<style>
  /* =============================================
     DESIGN SYSTEM
     =============================================
     Theme: The Founder's Broadsheet
     Fonts: Fraunces (serif display) · Syne (body) · Bricolage Grotesque (logo)
     Palette: Forest green (#1A332B) ↔ Cream (#F7F5F0) alternating
  ============================================= */

  :root {
    --forest:  #1A332B;
    --cream:   #F7F5F0;
    --sand:    #EDE9E1;
    --ink:     #1C1C1A;
    --copper:  #B85C38;
    --mid:     #4A6B5A;
    --border:  #1C1C1A;
    --border-light: rgba(28, 28, 26, 0.14);

    --font-display: 'Bricolage Grotesque', sans-serif;
    --font-body:    'Syne', system-ui, sans-serif;
    --font-logo:    'Bricolage Grotesque', sans-serif;

    --max-w:       1280px;
    --max-w-sm:    860px;
    --pad-x:       clamp(1.25rem, 4vw, 3.5rem);
  }

  /* =============================================
     GLOBAL RESET
  ============================================= */
  .page *,
  .page *::before,
  .page *::after {
    box-sizing: border-box;
  }

  .page {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink);
    background: var(--cream);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Grain overlay */
  .page::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }

  /* =============================================
     REVEAL
  ============================================= */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  /* =============================================
     LOGO BADGE
     Bricolage Grotesque · small-caps · #1A332B / #F7F5F0
  ============================================= */
  .logo-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.22em;
    background: var(--forest);
    color: var(--cream);
    padding: 0.55rem 1.05rem 0.6rem;
    text-decoration: none;
    font-family: var(--font-logo);
    font-weight: 700;
    font-size: 1.65rem;
    letter-spacing: 0.025em;
    line-height: 1;
    transition: opacity 0.2s;
  }
  .logo-badge:hover { opacity: 0.85; }

  .logo-builders {
    font-weight: 500;
    font-size: 0.76em;
    letter-spacing: 0.06em;
    opacity: 0.82;
  }

  .logo-badge-sm {
    font-size: 1.2rem;
    padding: 0.45rem 0.85rem 0.5rem;
  }

  /* =============================================
     NAV
  ============================================= */
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 200;
    background: var(--cream);
    border-bottom: 2px solid transparent;
    transition: border-color 0.35s, background 0.35s;
  }
  .nav.scrolled {
    border-bottom-color: var(--border);
    background: rgba(247, 245, 240, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.75rem var(--pad-x);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-cta {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--forest);
    text-decoration: none;
    letter-spacing: 0.01em;
    border: 2px solid var(--forest);
    padding: 0.5rem 1.25rem;
    transition: background 0.2s, color 0.2s;
  }
  .nav-cta:hover {
    background: var(--forest);
    color: var(--cream);
  }
  .nav-arrow { display: inline-block; transition: transform 0.2s; }
  .nav-cta:hover .nav-arrow { transform: translateX(3px); }

  /* =============================================
     CONTAINER
  ============================================= */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--pad-x);
  }

  /* =============================================
     SECTION DEFAULTS
  ============================================= */
  .section {
    padding: clamp(4rem, 8vw, 9rem) 0;
    position: relative;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
  }

  .section-title em { font-style: normal; }

  .section-title-inv {
    color: var(--cream);
  }

  .title-muted {
    color: var(--mid);
    font-style: normal;
  }

  /* =============================================
     HERO  (forest green)
  ============================================= */
  .hero {
    min-height: 100svh;
    background: var(--forest);
    border-bottom: 2px solid var(--border);
    position: relative;
    display: flex;
    flex-direction: column;
    padding-top: 5rem; /* nav offset */
  }

  .hero-inner {
    flex: 1;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) var(--pad-x);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: center;
    width: 100%;
  }

  .hero-eyebrow {
    font-family: var(--font-logo);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--mid);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 1.75rem;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(4rem, 8.5vw, 8.5rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--cream);
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-headline em {
    font-style: normal;
    color: rgba(247, 245, 240, 0.65);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: rgba(247, 245, 240, 0.65);
    max-width: 480px;
    margin: 0 0 clamp(2rem, 3vw, 3rem);
    line-height: 1.7;
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-hero {
    display: inline-block;
    background: var(--cream);
    color: var(--forest);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    padding: 0.85rem 2.2rem;
    letter-spacing: 0.02em;
    border: 2px solid var(--cream);
    transition: background 0.2s, color 0.2s;
  }
  .btn-hero:hover {
    background: transparent;
    color: var(--cream);
  }

  .hero-note {
    font-family: var(--font-logo);
    font-size: 0.78rem;
    color: var(--mid);
    letter-spacing: 0.05em;
  }

  /* FACES GRID — 2 columns x 3 rows */
  .hero-faces {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 2px solid rgba(247, 245, 240, 0.15);
  }

  .face-card {
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(247, 245, 240, 0.12);
    border-bottom: 1px solid rgba(247, 245, 240, 0.12);
    overflow: hidden;
  }
  .face-card:nth-child(2n)  { border-right: none; }
  .face-card:nth-last-child(-n+2) { border-bottom: none; }

  .face-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .face-silhouette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .face-firstname {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: rgba(247, 245, 240, 0.9);
    letter-spacing: -0.01em;
    line-height: 1;
    text-shadow: 0 1px 8px rgba(0,0,0,0.4);
  }

  .face-caption {
    padding: 0.55rem 0.75rem;
    background: rgba(247, 245, 240, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .face-fullname {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.7rem;
    color: var(--cream);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.01em;
  }

  .face-company {
    font-family: var(--font-logo);
    font-size: 0.62rem;
    color: var(--mid);
    letter-spacing: 0.05em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .hero-scroll {
    display: flex;
    justify-content: center;
    padding: 1.5rem 0;
  }

  .scroll-bar {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--mid), transparent);
    animation: scrolldrop 2s ease-in-out infinite;
  }

  @keyframes scrolldrop {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
    30%  { opacity: 1; }
    80%  { transform: scaleY(1); transform-origin: top; }
    100% { transform: scaleY(0); transform-origin: bottom; opacity: 0; }
  }

  /* =============================================
     PROBLEM  (cream)
  ============================================= */
  .section-problem {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  .problem-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
  }

  .problem-pull {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
    position: sticky;
    top: 5rem;
  }

  .problem-body p {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: #4A4A46;
    line-height: 1.75;
    margin: 0 0 1.25rem;
    font-weight: 400;
  }
  .problem-body p:last-child { margin-bottom: 0; }

  .problem-bridge {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    color: var(--copper);
    letter-spacing: -0.02em;
    margin: 2rem 0 0;
    line-height: 1;
  }

  /* =============================================
     WHO  (sand)
  ============================================= */
  .section-who {
    background: var(--sand);
    border-bottom: 2px solid var(--border);
  }

  .who-rows {
    margin-bottom: clamp(2rem, 4vw, 4rem);
    border-top: 1px solid var(--border-light);
  }

  .who-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--border-light);
    transition: padding-left 0.3s ease;
  }

  .who-row:hover { padding-left: 0.5rem; }

  .who-num {
    font-family: var(--font-logo);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--copper);
    letter-spacing: 0.06em;
    flex-shrink: 0;
    width: 2.5rem;
  }

  .who-row p {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .who-note {
    font-family: var(--font-body);
    font-size: 1rem;
    color: #666660;
    max-width: 600px;
    margin: 0;
    font-style: italic;
  }

  /* =============================================
     COMMUNITY  (forest green)
  ============================================= */
  .section-community {
    background: var(--forest);
    border-bottom: 2px solid var(--border);
    padding-bottom: clamp(4rem, 8vw, 9rem);
  }

  .community-header {
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .community-header .section-title { margin-bottom: 0; }

  .community-sub {
    font-size: 1rem;
    color: var(--mid);
    max-width: 380px;
    margin: 0;
    line-height: 1.65;
    text-align: right;
  }

  .builders-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid rgba(247, 245, 240, 0.12);
  }

  .builder-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-right: 1px solid rgba(247, 245, 240, 0.12);
    border-bottom: 1px solid rgba(247, 245, 240, 0.12);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }
  .builder-card:nth-child(3n) { border-right: none; }
  .builder-card:nth-last-child(-n+3) { border-bottom: none; }
  .builder-card:hover { transform: translateY(-4px); }

  .builder-photo {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .builder-silhouette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .builder-photo-tag {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    font-family: var(--font-logo);
    font-size: 0.62rem;
    font-weight: 600;
    color: rgba(247, 245, 240, 0.9);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(26, 51, 43, 0.6);
    padding: 0.2rem 0.5rem;
    backdrop-filter: blur(4px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .builder-card:hover .builder-photo-tag {
    opacity: 1;
    transform: none;
  }

  .builder-info {
    padding: 1.1rem 1.25rem 1.35rem;
    background: rgba(247, 245, 240, 0.04);
    flex: 1;
    transition: background 0.25s;
  }
  .builder-card:hover .builder-info {
    background: rgba(247, 245, 240, 0.08);
  }

  .builder-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--cream);
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .builder-role {
    font-family: var(--font-logo);
    font-size: 0.68rem;
    color: var(--mid);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.8rem;
  }

  .builder-building {
    font-size: 0.88rem;
    color: rgba(247, 245, 240, 0.5);
    margin: 0;
    line-height: 1.55;
    font-weight: 400;
  }

  /* =============================================
     BENEFITS  (cream)
  ============================================= */
  .section-benefits {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-bottom: clamp(2rem, 4vw, 4rem);
    border: 1px solid var(--border-light);
  }

  .benefit-item {
    padding: 2.2rem 1.75rem;
    border-right: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    transition: background 0.3s;
  }
  .benefit-item:hover { background: var(--sand); }
  .benefit-item:nth-child(3n) { border-right: none; }
  .benefit-item:nth-last-child(-n+3) { border-bottom: none; }

  .benefit-n {
    display: block;
    font-family: var(--font-logo);
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--copper);
    letter-spacing: 0.1em;
    margin-bottom: 1.1rem;
  }

  .benefit-item h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .benefit-item p {
    font-size: 0.95rem;
    color: #4A4A46;
    margin: 0;
    line-height: 1.65;
  }

  .benefits-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1.6rem var(--pad-x);
    border: 2px solid var(--ink);
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .banner-dot {
    color: var(--copper);
    font-style: normal;
  }

  /* =============================================
     STEPS  (sand)
  ============================================= */
  .section-steps {
    background: var(--sand);
    border-bottom: 2px solid var(--border);
  }

  .steps-track {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-bottom: clamp(2rem, 4vw, 4rem);
    border: 1px solid var(--border-light);
  }

  .step {
    flex: 1;
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--border-light);
  }
  .step:last-child { border-right: none; }

  .step-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    flex-shrink: 0;
    align-self: stretch;
    font-size: 1.4rem;
    color: var(--copper);
    border-right: 1px solid var(--border-light);
    font-family: var(--font-body);
  }

  .step-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    background: var(--forest);
    color: var(--cream);
    font-family: var(--font-display);
    font-style: normal;
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .step h3 {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: 1.7rem;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }

  .step p {
    font-size: 0.95rem;
    color: #4A4A46;
    margin: 0;
    line-height: 1.65;
  }

  .steps-note {
    font-family: var(--font-logo);
    font-size: 0.75rem;
    color: #888882;
    letter-spacing: 0.05em;
    margin: 0;
  }

  /* =============================================
     ORIGIN  (cream)
  ============================================= */
  .section-origin {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  .origin-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 6rem);
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
    align-items: start;
  }

  .origin-text p {
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    color: #4A4A46;
    line-height: 1.8;
    margin: 0 0 1.25rem;
  }
  .origin-text p:last-child { margin-bottom: 0; }

  .origin-text a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .origin-text a:hover { color: var(--copper); }

  .origin-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border-light);
  }

  .stat {
    padding: 1.75rem 1.5rem;
    border-right: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }
  .stat:nth-child(2n) { border-right: none; }
  .stat:nth-last-child(-n+2) { border-bottom: none; }

  .stat-n {
    display: block;
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--ink);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-l {
    font-family: var(--font-logo);
    font-size: 0.7rem;
    color: #888882;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .press-row {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: clamp(1.5rem, 3vw, 3rem);
    border-top: 1px solid var(--border-light);
  }

  .press-label {
    font-family: var(--font-logo);
    font-size: 0.68rem;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }

   .press-logo {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: 1.1rem;
    color: #BBBBBB;
    letter-spacing: -0.01em;
    transition: color 0.25s;
    text-decoration: none;
    cursor: pointer;
  }
  .press-logo:hover { color: var(--ink); }

  /* =============================================
     MADRID  (forest green)
  ============================================= */
  .section-madrid {
    background: var(--forest);
    border-bottom: 2px solid var(--border);
    overflow: hidden;
    position: relative;
  }

  .madrid-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 9rem) var(--pad-x);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 6rem);
    position: relative;
    z-index: 1;
  }

  .madrid-word {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(5rem, 14vw, 13rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--cream);
    margin: 0;
  }

  .madrid-desc {
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    color: rgba(247, 245, 240, 0.6);
    line-height: 1.7;
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .madrid-invite {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    font-size: clamp(1.3rem, 2.5vw, 2rem);
    color: var(--cream);
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 0;
  }

  .madrid-skyline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    line-height: 0;
    pointer-events: none;
    z-index: 0;
  }

  .madrid-skyline img {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.12;
    filter: invert(1) brightness(2);
    mix-blend-mode: screen;
  }

  /* =============================================
     FAQ  (cream)
  ============================================= */
  .section-faq {
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--border-light);
  }

  .faq-item {
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    transition: background 0.3s;
  }
  .faq-item:hover { background: var(--sand); }
  .faq-item:nth-child(2n) { border-right: none; }
  .faq-item:nth-last-child(-n+2) { border-bottom: none; }

  .faq-q {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--ink);
    margin: 0 0 0.75rem;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .faq-a {
    font-size: 0.95rem;
    color: #4A4A46;
    margin: 0;
    line-height: 1.7;
  }

  /* =============================================
     CTA  (forest green)
  ============================================= */
  .section-cta {
    background: var(--forest);
    padding: clamp(5rem, 10vw, 11rem) var(--pad-x);
    text-align: center;
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(4rem, 9vw, 8rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--cream);
    margin: 0 0 clamp(2.5rem, 4vw, 4rem);
  }
  .cta-headline em {
    font-style: normal;
    color: rgba(247, 245, 240, 0.55);
  }

  .cta-action { margin-bottom: 1.75rem; }

  .btn-apply {
    display: inline-block;
    background: var(--cream);
    color: var(--forest);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    padding: 1.1rem 3.5rem;
    letter-spacing: 0.02em;
    border: 2px solid var(--cream);
    transition: background 0.2s, color 0.2s;
  }
  .btn-apply:hover {
    background: transparent;
    color: var(--cream);
  }

  .cta-note {
    font-family: var(--font-logo);
    font-size: 0.75rem;
    color: var(--mid);
    letter-spacing: 0.06em;
    margin: 0;
  }

  /* =============================================
     FOOTER  (cream)
  ============================================= */
  .footer {
    background: var(--cream);
    border-top: 2px solid var(--border);
    padding: 2.5rem var(--pad-x);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: #888882;
    font-family: var(--font-logo);
  }

  .footer-by {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-by-label {
    font-family: var(--font-logo);
    font-size: 0.68rem;
    color: #AAAAAA;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-by a {
    font-size: 0.9rem;
    color: #666660;
    text-decoration: none;
    transition: color 0.2s;
    font-family: var(--font-body);
    font-weight: 500;
  }
  .footer-by a:hover { color: var(--ink); }

  /* =============================================
     RESPONSIVE — TABLET
  ============================================= */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-faces {
      grid-template-columns: repeat(3, 1fr);
    }
    .face-card:nth-child(2n) { border-right: 1px solid rgba(247,245,240,0.12); }
    .face-card:nth-child(3n) { border-right: none; }
    .face-card:nth-last-child(-n+2) { border-bottom: 1px solid rgba(247,245,240,0.12); }
    .face-card:nth-last-child(-n+3) { border-bottom: none; }

    .builders-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .builder-card:nth-child(3n) { border-right: 1px solid rgba(247,245,240,0.12); }
    .builder-card:nth-last-child(-n+3) { border-bottom: 1px solid rgba(247,245,240,0.12); }
    .builder-card:nth-child(2n) { border-right: none; }
    .builder-card:nth-last-child(-n+2) { border-bottom: none; }

    .origin-layout {
      grid-template-columns: 1fr;
    }
    .origin-stats {
