---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
import { events, cohosts } from '../data/events';
import { people } from '../data/people';
import { projects } from '../data/projects';
import { sisters } from '../data/friends';
import sampliaLogo from '../assets/logos/friends/samplia.svg';
import xIcon from '../assets/logos/socials/x.svg';
import linkedinIcon from '../assets/logos/socials/linkedin.svg';
import osoCrest from '../assets/brand/oso-crest.png';

const covers = import.meta.glob<{ default: ImageMetadata }>('../assets/events/*/cover.jpeg', { eager: true });
const coverFor = (slug: string) => covers[`../assets/events/${slug}/cover.jpeg`]?.default;

// All event photos (covers excluded) feed the two hero strips. The exact
// selection is placeholder for now — swap freely later.
const allHeroPhotos = Object.entries(
  import.meta.glob<{ default: ImageMetadata }>('../assets/events/*/*.jpeg', { eager: true })
)
  .filter(([path]) => !path.endsWith('cover.jpeg'))
  .map(([, m]) => m.default);

// Cap how many load on the homepage — the strips only show a few at a time and
// scroll, so there's no need to ship all ~90 event photos in the hero.
const PER_STRIP = 14;
const stripTop = allHeroPhotos.filter((_, i) => i % 2 === 0).slice(0, PER_STRIP);
const stripBottom = allHeroPhotos.filter((_, i) => i % 2 === 1).slice(0, PER_STRIP);
// Both strips feed one lightbox; indices are top photos first, then bottom.
const lightboxPhotos = [...stripTop, ...stripBottom];

const friendLogos = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/friends/*.svg', { eager: true });
const cohostLogo = (name: string) => friendLogos[`../assets/logos/friends/${name}.svg`]?.default;
// These logos are already white/light-toned, so they skip the white-ink filter.
const rawCohosts = new Set(['cursor']);

const projectLogos = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/projects/*.{svg,png,webp,avif}', { eager: true });
const projectLogo = (file?: string) => (file ? projectLogos[`../assets/logos/projects/${file}`]?.default : undefined);

const sisterLogos = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/sisters/*.{svg,png,jpg}', { eager: true });
const sisterLogo = (file?: string) => (file ? sisterLogos[`../assets/logos/sisters/${file}`]?.default : undefined);
const isRaster = (file?: string) => !!file && /\.(jpg|jpeg)$/.test(file);

const portraits = import.meta.glob<{ default: ImageMetadata }>('../assets/profiles/*.png', { eager: true });
const portraitFor = (slug: string) => portraits[`../assets/profiles/${slug}.png`]?.default;

// Parse the date-only string as UTC so the rendered day doesn't shift with the
// build machine's timezone.
const fmt = (iso: string) => {
  const [y, m, d] = iso.split('T')[0].split('-').map(Number);
  return new Date(Date.UTC(y, m - 1, d))
    .toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC' })
    .toLowerCase();
};

// Repeat the focus words enough times that one "reel" overflows even ultra-wide
// screens; two identical reels animated by exactly -50% give a seamless loop.
const ticker = Array.from({ length: 5 }, () => site.focus).flat();
---

<Layout>
  <!-- section subnav -->
  <nav class="subnav mono" aria-label="page sections">
    <div class="wrap subnav-inner">
      <a href="#deal">the deal</a>
      <a href="#events">events</a>
      <a href="#residents">residents</a>
      <a href="#builds">companies</a>
      <a href="#off-hours">off-hours</a>
      <a href="#friends">friends</a>
    </div>
  </nav>

  <!-- hero -->
  <section class="hero" id="hero">
    <div class="hero-top">
      {/* el oso y el madroño — Madrid's coat of arms, as a faint crest */}
      <img class="hero-crest" src={osoCrest.src} alt="" aria-hidden="true" />
      <div class="wrap">
        <h1>the builders' <br class="brk-m" /><span class="nowrap">house in <br class="brk-d" /><span class="proper">Madrid</span></span></h1>
        <p class="lede hero-lede">
          Where builders, founders and VCs meet, hosted by<!--
          --><a class="samplia-inline" href="https://samplia.com" target="_blank" rel="noopener" aria-label="Samplia"><img src={sampliaLogo.src} alt="Samplia" /></a>
        </p>
        <div class="hero-ctas">
          <a class="btn solid" href={site.whatsapp}>whatsapp group →</a>
          <a class="btn" href="#events">events</a>
        </div>
      </div>
    </div>

    <!-- photos / marquee / photos band -->
    <div class="strip">
      {stripTop.map((img, i) => (
        <button class="strip-shot" data-index={i} aria-label="expand photo">
          <Image src={img} alt="inside the mad builders house" width={420} class="strip-img" loading="lazy" />
        </button>
      ))}
    </div>
    <div class="ticker mono" aria-hidden="true">
      <div class="ticker-track">
        {[0, 1].map(() => (
          <div class="reel">
            {ticker.map((f) => (
              <span class="tick">{f} <i>///</i> </span>
            ))}
          </div>
        ))}
      </div>
    </div>
    <div class="strip">
      {stripBottom.map((img, i) => (
        <button class="strip-shot" data-index={stripTop.length + i} aria-label="expand photo">
          <Image src={img} alt="inside the mad builders house" width={420} class="strip-img" loading="lazy" />
        </button>
      ))}
    </div>
  </section>

  <!-- the deal -->
  <section class="section light" id="deal">
    <div class="wrap">
      <h2 class="section-title">the deal</h2>
      <p class="lede"><span class="nowrap">no bullshit.</span> <span class="nowrap">just building.</span></p>
      <div class="deal-grid">
        <div class="deal">
          <h3>a real house</h3>
          <p>
            A free workspace in the middle of Madrid. No membership fees, no equity, no hidden
            costs. We keep it small so it stays useful.
          </p>
        </div>
        <div class="deal">
          <h3>proof of work</h3>
          <p>
            We don't curate by résumé. We show up, we don't ask for permission, we build, we share.
          </p>
        </div>
        <div class="deal">
          <h3>an open door</h3>
          <p>
            Founders, companies and VCs pass through the house every week. Visiting Madrid? Come
            say hi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- events -->
  <section class="section" id="events">
    <div class="wrap">
      <h2 class="section-title">events</h2>
      <p class="lede">
        Firesides with founders, hands-on hack sessions, demo nights. Subscribe to
        <a href={site.lumaCalendar} target="_blank" rel="noopener">our luma calendar</a> to get notified about new events.
      </p>
      <div class="event-grid">
        {events.map((e) => (
          <a class="event-card" href={`/events/${e.slug}/`}>
            {coverFor(e.slug) && <Image src={coverFor(e.slug)!} alt={e.title} width={520} class="event-cover" />}
            <div class="event-meta">
              <span class="mono event-date">{fmt(e.date)}</span>
              <h3>{e.title}</h3>
            </div>
          </a>
        ))}
      </div>
      <div class="cohosts">
        <span class="mono cohost-label">co-hosted with our friends</span>
        <div class="cohost-row">
          {cohosts.map(
            (c) =>
              cohostLogo(c.name) && (
                <a class="cohost-link" href={c.url} target="_blank" rel="noopener" title={c.name}>
                  <img
                    src={cohostLogo(c.name)!.src}
                    alt={c.name}
                    class:list={['cohost-img', { raw: rawCohosts.has(c.name) }]}
                  />
                </a>
              )
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- residents -->
  <section class="section light" id="residents">
    <div class="wrap">
      <h2 class="section-title">residents</h2>
      <p class="lede">The current cohort, building out of the house right now.</p>
      <div class="people-grid">
        {people.map((p) => (
          <div class="person">
            {portraitFor(p.slug) && <Image src={portraitFor(p.slug)!} alt={p.name} width={400} class="person-img" />}
            <div class="person-row">
              <span class="person-name">{p.name}</span>
              <span class="person-links">
                {p.x && (
                  <a
                    class="person-link"
                    href={p.x}
                    target="_blank"
                    rel="noopener"
                    aria-label={`${p.name} on X`}
                    style={`-webkit-mask-image:url(${xIcon.src});mask-image:url(${xIcon.src})`}
                  ></a>
                )}
                {p.linkedin && (
                  <a
                    class="person-link"
                    href={p.linkedin}
                    target="_blank"
                    rel="noopener"
                    aria-label={`${p.name} on LinkedIn`}
                    style={`-webkit-mask-image:url(${linkedinIcon.src});mask-image:url(${linkedinIcon.src})`}
                  ></a>
                )}
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="join-note" id="join">
        <h3><span class="nowrap">the house is full</span> <span class="nowrap">(for now)</span></h3>
        <p>
          It filled up faster than we expected, so we've paused new applications while the current
          cohort settles in. But the building doesn't stop. Join the WhatsApp community to stay
          close. You'll meet the founders, and you'll be first to know when spots open.
        </p>
        <a class="btn solid" href={site.whatsapp}>whatsapp group →</a>
      </div>
    </div>
  </section>

  <!-- builds -->
  <section class="section" id="builds">
    <div class="wrap">
      <h2 class="section-title">companies</h2>
      <p class="lede">A few of the companies our residents are building.</p>
      <div class="project-grid">
        {projects.map((pr) => (
          <a class="project" href={pr.url} target="_blank" rel="noopener">
            {projectLogo(pr.logo) ? (
              <img src={projectLogo(pr.logo)!.src} alt={pr.name} class="project-logo" />
            ) : (
              <h3>{pr.name}</h3>
            )}
            <p>{pr.tagline}</p>
            <span class="mono project-link">visit →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- off-hours -->
  <section class="section light" id="off-hours">
    <div class="wrap">
      <h2 class="section-title">off-hours</h2>
      <p class="lede">we touch grass, too.</p>
      <div class="club-grid">
        <div class="club">
          <h3>book club</h3>
          <p>One book a month. Starting soon.</p>
        </div>
        <div class="club">
          <h3>running club</h3>
          <p>Easy morning runs through Retiro, and brunch before the laptops open. Starting soon.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- sisters -->
  <section class="section" id="friends">
    <div class="wrap">
      <h2 class="section-title">friends</h2>
      <p class="lede">Sister houses around the world, building places like ours and sharing the same values. If you're part of one of them, our door is open.</p>
      <div class="sister-wall">
        {sisters.map((s) => {
          const logo = sisterLogo(s.logo);
          const Tag = s.url ? 'a' : 'div';
          return (
            <Tag
              class="sister-tile"
              title={s.name}
              href={s.url}
              target={s.url ? '_blank' : undefined}
              rel={s.url ? 'noopener' : undefined}
            >
              {s.flag && <span class="sister-flag">{s.flag}</span>}
              {logo ? (
                <img
                  src={logo.src}
                  alt={s.name}
                  class={isRaster(s.logo) ? 'sister-raster' : s.ink ? 'sister-ink' : 'sister-natural'}
                />
              ) : (
                <span class="sister-name">{s.name}</span>
              )}
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <dialog id="hero-lightbox">
    <button id="hlb-close" class="mono" aria-label="close">close ×</button>
    <button id="hlb-prev" class="mono" aria-label="previous">←</button>
    <div id="hlb-stage">
      {lightboxPhotos.map((p, i) => (
        <Image src={p} alt="inside the mad builders house" width={1600} class="hlb-img" data-index={i} loading="lazy" />
      ))}
    </div>
    <button id="hlb-next" class="mono" aria-label="next">→</button>
  </dialog>
</Layout>

<script>
  // Scroll-spy: highlight the subnav link for the section in view.
  const subLinks = [...document.querySelectorAll<HTMLAnchorElement>('.subnav a')];
  const subLinkFor = new Map(subLinks.map((a) => [a.getAttribute('href')!.slice(1), a]));
  const spy = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        subLinks.forEach((a) => a.classList.remove('active'));
        // Hero in view = nothing active
        if ((e.target as HTMLElement).id !== 'hero') {
          subLinkFor.get((e.target as HTMLElement).id)?.classList.add('active');
        }
      }
    },
    { rootMargin: '-45% 0px -50% 0px' }
  );
  document.querySelectorAll<HTMLElement>('section[id]').forEach((s) => spy.observe(s));

  const dialog = document.getElementById('hero-lightbox') as HTMLDialogElement;
  if (dialog) {
    const imgs = [...dialog.querySelectorAll<HTMLImageElement>('.hlb-img')];
    let current = 0;

    const show = (i: number) => {
      current = (i + imgs.length) % imgs.length;
      imgs.forEach((img, j) => (img.style.display = j === current ? 'block' : 'none'));
    };

    document.querySelectorAll<HTMLButtonElement>('.strip-shot').forEach((btn) => {
      btn.addEventListener('click', () => {
        show(Number(btn.dataset.index));
        dialog.showModal();
      });
    });

    document.getElementById('hlb-close')!.addEventListener('click', () => dialog.close());
    document.getElementById('hlb-prev')!.addEventListener('click', () => show(current - 1));
    document.getElementById('hlb-next')!.addEventListener('click', () => show(current + 1));
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  }
</script>

<style>
  .subnav {
    position: sticky;
    top: 64px;
    z-index: 90;
    background: color-mix(in srgb, var(--green) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .subnav-inner {
    display: flex;
    gap: 22px;
    align-items: center;
    height: 46px;
    overflow-x: auto;
    scrollbar-width: none;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .subnav-inner::-webkit-scrollbar { display: none; }
  .subnav a {
    color: var(--cream-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .subnav a:hover,
  .subnav a.active {
    color: var(--cream);
  }
  .subnav a.active {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }
  /* sections need breathing room so the sticky nav + subnav don't cover the heading on jump */
  section[id] {
    scroll-margin-top: 118px;
  }

  .hero {
    padding: 64px 0 0;
    overflow: hidden;
    --strip-h: 188px;
  }
  .hero-top {
    position: relative;
  }
  .hero-top > .wrap {
    position: relative;
    z-index: 1;
  }
  .hero-crest {
    position: absolute;
    top: 50%;
    /* hug the content column on ultra-wide instead of floating at the far edge */
    right: max(clamp(-40px, 1vw, 24px), calc((100% - 1280px) / 2));
    transform: translateY(-50%);
    height: 112%;
    max-height: 540px;
    width: auto;
    opacity: 0.10;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .hero h1 {
    font-size: clamp(40px, 7vw, 92px);
    text-transform: lowercase;
    margin: 0 0 22px;
    color: var(--cream-dim);
  }
  .hero h1 .proper {
    text-transform: none;
    color: var(--cream);
  }
  /* desktop: break before "Madrid" so it sits alone on line 2 */
  .brk-m {
    display: none;
  }
  .nowrap {
    white-space: nowrap;
  }
  .hero-lede {
    font-size: 20px;
    max-width: 580px;
  }
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 30px 0 52px;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .hero {
      padding: 36px 0 0;
      --strip-h: 132px;
    }
    .hero-crest {
      display: none;
    }
    .hero h1 {
      margin: 0 0 16px;
    }
    /* mobile: break after "the builders'" so "house in Madrid" stays together */
    .brk-d {
      display: none;
    }
    .brk-m {
      display: inline;
    }
    .hero-lede {
      font-size: 17px;
    }
    .hero-lede .samplia-inline img {
      height: 18px;
      padding: 3px 6px;
    }
    .hero-ctas {
      margin: 22px 0 32px;
    }
  }
  .samplia-inline {
    display: inline-flex;
    vertical-align: middle;
    margin-left: 9px;
  }
  .samplia-inline img {
    height: 24px;
    width: auto;
    display: block;
    background: var(--cream);
    border-radius: 5px;
    padding: 4px 7px;
    opacity: 0.9;
    transition: opacity 0.15s;
  }
  .samplia-inline:hover img {
    opacity: 1;
  }

  .ticker {
    overflow: hidden;
    padding: 6px 0;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream-dim);
    white-space: nowrap;
    max-width: 1600px;
    margin-inline: auto;
  }
  .ticker-track {
    display: inline-flex;
    width: max-content;
    animation: scroll 60s linear infinite;
  }
  .reel {
    flex-shrink: 0;
    white-space: nowrap;
  }
  .tick i {
    font-style: normal;
    color: var(--cream-faint);
    margin: 0 14px;
  }
  @media (max-width: 640px) {
    .ticker {
      font-size: 10px;
      letter-spacing: 0.1em;
    }
    .tick i {
      margin: 0 9px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
  @keyframes scroll {
    to {
      transform: translateX(-50%);
    }
  }

  .strip {
    display: flex;
    gap: 10px;
    padding: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    max-width: 1600px;
    margin-inline: auto;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 7%, #000 93%, transparent);
    mask-image: linear-gradient(to right, transparent, #000 7%, #000 93%, transparent);
  }
  .strip::-webkit-scrollbar {
    display: none;
  }
  .strip-shot {
    flex-shrink: 0;
    display: block;
    height: var(--strip-h);
    padding: 0;
    margin: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: 6px;
  }
  .strip :global(.strip-img) {
    display: block;
    height: var(--strip-h);
    width: auto;
    object-fit: cover;
    border-radius: 6px;
    filter: saturate(0.92);
    transition: filter 0.15s;
  }
  .strip-shot:hover :global(.strip-img) {
    filter: saturate(1);
  }

  .deal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 28px;
    margin-top: 48px;
  }
  .deal {
    border: 1px solid rgba(26, 52, 43, 0.14);
    border-radius: 10px;
    padding: 28px;
    background: #fff;
  }
  .deal h3 {
    font-size: 22px;
    text-transform: lowercase;
    margin-bottom: 12px;
  }
  .deal p {
    color: rgba(26, 52, 43, 0.72);
    margin: 0;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(235px, 1fr));
    gap: 18px;
    margin-top: 48px;
  }
  .event-card {
    text-decoration: none;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: var(--green-deep);
    transition: transform 0.18s ease, border-color 0.18s ease;
  }
  .event-card:hover {
    transform: translateY(-3px);
    border-color: var(--cream-faint);
  }
  .event-card :global(.event-cover) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .event-meta {
    padding: 14px 16px 18px;
  }
  .event-date {
    color: var(--cream-faint);
    font-size: 11px;
  }
  .event-meta h3 {
    font-size: 16px;
    line-height: 1.3;
    margin: 7px 0 0;
  }

  .cohosts {
    margin-top: 64px;
    text-align: center;
  }
  .cohost-label {
    color: var(--cream-faint);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .cohost-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(28px, 5vw, 56px);
    flex-wrap: wrap;
    margin-top: 26px;
  }
  .cohost-link {
    display: inline-flex;
  }
  .cohost-img {
    height: 26px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .cohost-img.raw {
    filter: none;
  }
  .cohost-link:hover .cohost-img {
    opacity: 1;
  }

  .people-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 22px;
    margin-top: 48px;
  }
  .person :global(.person-img) {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
    filter: grayscale(0.25);
    transition: filter 0.2s;
  }
  .person:hover :global(.person-img) {
    filter: none;
  }
  .person-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
    gap: 8px;
  }
  .person-name {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    min-width: 0;
  }
  .person-links {
    display: flex;
    gap: 9px;
    align-items: center;
    flex-shrink: 0;
  }
  .person-link {
    width: 15px;
    height: 15px;
