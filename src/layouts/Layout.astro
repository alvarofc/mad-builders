---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { site } from '../data/site';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "mad builders — the builders' house in madrid", description = site.description } = Astro.props;

const socialIcons = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/socials/*.svg', { eager: true });
const iconFor = (icon: string) => socialIcons[`../assets/logos/socials/${icon}.svg`]?.default;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="wordmark">mad <span>builders</span></a>
        <nav class="links mono">
          <a href="/#events">events</a>
          <a href="/#residents">residents</a>
          <a href="/#builds">projects</a>
          {/* madrid page hidden from nav for now — still live at /madrid */}
          <a href={site.whatsapp} class="cta">whatsapp →</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="footer">
      <div class="wrap footer-bar mono">
        <span>madrid, spain</span>
        <div class="socials">
          {site.socials.map(
            (s) =>
              iconFor(s.icon) && (
                <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} title={s.label}>
                  <img src={iconFor(s.icon)!.src} alt={s.label} />
                </a>
              )
          )}
        </div>
        <span>est. 2025 · mad.builders</span>
      </div>
    </footer>
    <Analytics />
  </body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--green) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .wordmark {
    font-family: 'Bricolage Grotesque', var(--font-sans);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .wordmark span,
  .big-mark span {
    color: var(--cream-dim);
    font-weight: 400;
  }
  .links {
    display: flex;
    gap: 26px;
    align-items: center;
  }
  .links a {
    text-decoration: none;
    color: var(--cream-dim);
    transition: color 0.15s;
  }
  .links a:hover {
    color: var(--cream);
  }
  .links .cta {
    color: var(--cream);
    border: 1px solid var(--line);
    padding: 8px 16px;
    border-radius: 999px;
  }
  .links .cta:hover {
    background: var(--cream);
    color: var(--green);
  }
  @media (max-width: 640px) {
    .links {
      gap: 16px;
      font-size: 12px;
    }
    .links a:not(.cta):not(:nth-child(-n + 3)) {
      display: none;
    }
  }

  .footer {
    border-top: 1px solid var(--line);
    padding: 30px 0;
    background: var(--green-deep);
  }
  .footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    color: var(--cream-faint);
  }
  .socials {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .socials img {
    height: 18px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .socials a:hover img {
    opacity: 1;
  }
  @media (max-width: 640px) {
    .footer-bar {
      justify-content: center;
      text-align: center;
    }
  }
</style>
