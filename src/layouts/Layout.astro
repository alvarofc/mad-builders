---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { site } from '../data/site';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  structuredData?: Record<string, any> | Array<Record<string, any>>;
}

const {
  title = "the builders' house in Madrid | mad.builders",
  description = site.description,
  noindex,
  structuredData,
} = Astro.props;

const socialIcons = import.meta.glob<{ default: ImageMetadata }>('../assets/logos/socials/*.svg', { eager: true });
const iconFor = (icon: string) => socialIcons[`../assets/logos/socials/${icon}.svg`]?.default;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} noindex={noindex} structuredData={structuredData} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="nav">
      <div class="wrap nav-inner">
        <a href="/" class="wordmark">mad<span>.builders</span></a>
        <nav class="links mono">
          <a href="/">home</a>
          <a href="/madrid">Madrid</a>
          <a href={site.whatsapp} class="cta">whatsapp →</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap footer-top">
        <div class="footer-brand">
          <a href="/" class="footer-mark">mad<span>.builders</span></a>
          <a class="footer-map mono" href="https://maps.app.goo.gl/3MxVbkH5V8UQwMMu6" target="_blank" rel="noopener">pl. del callao 1, Madrid ↗</a>
        </div>
        <nav class="footer-nav mono" aria-label="footer">
          <a href="/brand">brand guide</a>
        </nav>
      </div>
      <div class="wrap footer-bar mono">
        <span>est. 2025 · mad.builders</span>
        <div class="socials">
          {site.socials.map((s) => {
            const icon = iconFor(s.icon);
            if (!icon) return null;
            const img = <img src={icon.src} alt={s.label} title={s.label} />;
            return s.url ? (
              <a href={s.url} target="_blank" rel="noopener" aria-label={s.label}>{img}</a>
            ) : (
              img
            );
          })}
        </div>
      </div>
    </footer>
    <Analytics />
  </body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--green) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .wordmark {
    font-family: 'Bricolage Grotesque', var(--font-sans);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .wordmark span {
    color: var(--cream-dim);
    font-weight: 400;
  }
  .links {
    display: flex;
    gap: 26px;
    align-items: center;
  }
  .links a {
    text-decoration: none;
    color: var(--cream-dim);
    transition: color 0.15s;
  }
  .links a:hover {
    color: var(--cream);
  }
  .links .cta {
    color: var(--cream);
    border: 1px solid var(--line);
    padding: 8px 16px;
    border-radius: 999px;
  }
  .links .cta:hover {
    background: var(--cream);
    color: var(--green);
  }
  @media (max-width: 640px) {
    .links {
      gap: 16px;
      font-size: 12px;
    }
    .wordmark {
      white-space: nowrap;
    }
    /* mobile: keep the page links (home, madrid), drop the whatsapp CTA */
    .links .cta {
      display: none;
    }
  }

  .footer {
    border-top: 1px solid var(--line);
    padding: 56px 0 28px;
    background: var(--green-deep);
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
    padding-bottom: 38px;
  }
  .footer-mark {
    font-family: 'Bricolage Grotesque', var(--font-sans);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--cream);
  }
  .footer-mark span {
    color: var(--cream-dim);
    font-weight: 400;
  }
  .footer-map {
    display: block;
    margin-top: 16px;
    color: var(--cream-faint);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .footer-map:hover {
    color: var(--cream);
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .footer-nav a {
    color: var(--cream-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover {
    color: var(--cream);
  }
  .footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    color: var(--cream-faint);
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }
  .socials {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .socials img {
    height: 18px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .socials img:hover {
    opacity: 1;
  }
  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 28px;
    }
    .footer-nav {
      align-items: flex-start;
    }
    .footer-bar {
      justify-content: center;
      text-align: center;
    }
  }
</style>
